# Di Linux, isi dengan output `id -u` supaya permission file volume cocok.
# Di Mac/Windows (Docker Desktop) boleh dibiarkan default 50000.
AIRFLOW_UID=50000

# Dipakai utk enkripsi Connection/Variable sensitif di metadata DB.
# Sudah di-generate sekali di bawah ini utk kebutuhan dev/local.
# Generate ulang kalau perlu:  python3 -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
FERNET_KEY=PsLyP3KWr1F4za529oLCXJejOdsiQymv3D9EtFwgXHE=

# Login default UI Airflow
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# JWT dipakai internal antar-komponen Airflow 3 (apiserver <-> scheduler dll).
# Ganti ke string acak yang lebih panjang utk pemakaian selain local/dev.
AIRFLOW__API_AUTH__JWT_SECRET=airflow_jwt_secret_change_me
AIRFLOW__API_AUTH__JWT_ISSUER=airflow

# JANGAN dipakai utk nambah dependency permanen (lambat, terinstall ulang tiap start).
# requirements.txt + Dockerfile sudah handle pandas & provider Postgres.
_PIP_ADDITIONAL_REQUIREMENTS=

# Postgres Data Warehouse (postgres-dw) Config
POSTGRES_DW_USER=banking
POSTGRES_DW_PASSWORD=banking123
POSTGRES_DW_DB=banking_dw

# Superset Config
SUPERSET_SECRET_KEY=please_change_this_secret_key